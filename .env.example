# ---------------------------------------------------------------------------
# Arc — Circle's stablecoin-native L1. USDC is the gas token.
# ---------------------------------------------------------------------------
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_WS_URL=wss://rpc.testnet.arc.network
# Chain id 5042002. Explorer https://testnet.arcscan.app
# Fund test wallets at https://faucet.circle.com (select Arc Testnet).

# ---------------------------------------------------------------------------
# Circle developer platform — console.circle.com
# ---------------------------------------------------------------------------
# API key format: PREFIX:ID:SECRET
CIRCLE_API_KEY=
# 32-byte hex entity secret. Generate, then register its ciphertext with Circle
# before the first request or every call will fail.
ENTITY_SECRET=

# Circle's blockchain identifier for Arc in the Wallets / SCP APIs.
CIRCLE_BLOCKCHAIN=ARC-TESTNET

# Created once via `createWalletSet()` — holds every Vane user wallet.
CIRCLE_WALLET_SET_ID=

# The falcon's own wallet. It may call settle() and hold(); it never holds user funds.
CIRCLE_AGENT_WALLET_ID=

# Smart Contract Platform ids, filled in by the deploy script.
CIRCLE_ESCROW_CONTRACT_ID=
CIRCLE_REGISTRY_CONTRACT_ID=

# ---------------------------------------------------------------------------
# Deployed contract addresses on Arc (filled in by the deploy script)
# ---------------------------------------------------------------------------
VANE_ESCROW_ADDRESS=
VANE_REGISTRY_ADDRESS=

# Where the 8% protocol fee is paid.
VANE_FEE_RECIPIENT=

# ---------------------------------------------------------------------------
# Local deploy only — a funded Arc testnet key, if deploying with Foundry
# instead of the Circle Smart Contract Platform.
# ---------------------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=
